{
  // MCP servers can be started directly from this file within VSCode
  "servers": {
    // https://github.com/Coding-Solo/godot-mcp
    "godot": {
      "command": "node",
      // Edit this to point to where ever you installed godot-mcp
      "args": ["/home/valk/Downloads/godot-mcp/build/index.js"],
      "env": {
        "DEBUG": "true",
        // Edit this to point to where Godot is installed
        "GODOT_PATH": "/opt/godot-4.6.1/Godot_v4.6.1-stable_mono_linux.x86_64"
      }
    },
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "${workspaceFolder}"
      ]
    }
  }
}
