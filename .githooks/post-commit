#!/usr/bin/env bash
# post-commit: intentionally empty.
# Build logic was moved to pre-commit because GitHub Desktop (libgit2) does not
# invoke post-commit hooks.

build_godotutils() {
    echo "[post-commit] Building GodotUtils..."
    if dotnet build "$REPO_ROOT/Template.GodotUtils/GodotUtils.csproj" -p:BuildExtras=true; then
        echo "[post-commit] GodotUtils built — DLLs copied to Framework/Libraries."
    else
        echo "[post-commit] GodotUtils build FAILED." >&2
    fi
}

build_visualize() {
    echo "[post-commit] Building Visualize..."
    if dotnet build "$REPO_ROOT/Template.Visualize/Visualize.csproj" -p:BuildExtras=true; then
        echo "[post-commit] Visualize built — DLLs copied to Framework/Libraries."
    else
        echo "[post-commit] Visualize build FAILED." >&2
    fi
}

build_packetgen() {
    echo "[post-commit] Building PacketGen..."
    local proj_file="$REPO_ROOT/Template.PacketGen/PacketGen/PacketGen.csproj"

    if ! dotnet build "$proj_file" -c Release; then
        echo "[post-commit] PacketGen build FAILED." >&2
        return 1
    fi

    # Locate the nupkg produced by the release build
    local out_dir="$REPO_ROOT/Template.PacketGen/PacketGen/bin/Release/netstandard2.0"
    local new_nupkg
    new_nupkg="$(find "$out_dir" -maxdepth 1 -name "PacketGen.*.nupkg" | head -1)"

    if [ -z "$new_nupkg" ]; then
        echo "[post-commit] No PacketGen nupkg found in $out_dir." >&2
        return 1
    fi

    # Replace the old nupkg in Framework/Libraries
    find "$LIBS" -maxdepth 1 -name "PacketGen.*.nupkg" -delete
    cp "$new_nupkg" "$LIBS/"
    echo "[post-commit] $(basename "$new_nupkg") copied to Framework/Libraries."

    # Bump the patch segment of the version for the next release
    local current_version
    current_version="$(grep -oP '(?<=<Version>)[^<]+' "$proj_file" | head -1)"
    if [ -n "$current_version" ]; then
        local major minor patch
        IFS='.' read -r major minor patch <<< "$current_version"
        local next_version="$major.$minor.$((patch + 1))"
        sed -i "s|<Version>$current_version</Version>|<Version>$next_version</Version>|" "$proj_file"
        echo "[post-commit] PacketGen version bumped $current_version → $next_version (commit PacketGen.csproj to record the bump)."
    fi
}

# GodotUtils must be built before Visualize (Visualize depends on GodotUtils.dll)
if echo "$CHANGED" | grep -q "^Template\.GodotUtils/"; then
    build_godotutils
fi

if echo "$CHANGED" | grep -q "^Template\.Visualize/"; then
    build_visualize
fi

if echo "$CHANGED" | grep -q "^Template\.PacketGen/"; then
    build_packetgen
fi
