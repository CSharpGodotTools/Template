#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 2 ]; then
    echo "Usage: $(basename "$0") <project-path> <format-mode> [file ...]"
    exit 1
fi

project_path="$1"
format_mode="$2"
shift 2

declare -a includes=("$@")

if [ "${#includes[@]}" -eq 0 ]; then
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=.githooks/scripts/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

echo "[pre-commit] Formatting $(basename "$project_path") (${#includes[@]} staged C# file(s))..."
printf '[pre-commit]   include: %s\n' "${includes[@]}"

case "${format_mode,,}" in
    whitespace)
        dotnet_cmd format whitespace "$project_path" --no-restore --include "${includes[@]}"
        ;;
    full)
        dotnet_cmd format "$project_path" --no-restore --include "${includes[@]}"
        ;;
    *)
        echo "[pre-commit] Invalid format mode: $format_mode (expected: whitespace or full)"
        exit 1
        ;;
esac

git add -- "${includes[@]}"