#!/usr/bin/env bash
# post-merge: syncs root .editorconfig to all subproject roots when it changed during the merge.

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Only sync when .editorconfig was part of the merged changes
if ! git diff-tree --no-commit-id -r HEAD --name-only | grep -q "^\.editorconfig$"; then
    exit 0
fi

SRC="$REPO_ROOT/.editorconfig"

SUBPROJECTS=(
    "Template"
    "Template.GodotUtils"
    "Template.PacketGen"
    "Template.Visualize"
)

for dir in "${SUBPROJECTS[@]}"; do
    dest="$REPO_ROOT/$dir/.editorconfig"
    cp "$SRC" "$dest"
    echo "[post-merge] Updated $dir/.editorconfig"
done

exit 0
