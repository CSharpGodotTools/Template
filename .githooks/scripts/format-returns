#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
    exit 0
fi

for file_path in "$@"; do
    if [ ! -f "$file_path" ]; then
        continue
    fi

    perl -0777 -i -pe '
        my $control = qr/(?:if\s*\([^\r\n]*\)|else\s+if\s*\([^\r\n]*\)|else|for\s*\([^\r\n]*\)|foreach\s*\([^\r\n]*\)|while\s*\([^\r\n]*\)|using\s*\([^\r\n]*\)|lock\s*\([^\r\n]*\)|fixed\s*\([^\r\n]*\))/;
        my $ret = qr/return(?:\s+(?:true|false))?\s*;/;

        # Brace on the next line.
        s{(^([ \t]*$control[^\r\n]*)\r?\n([ \t]*)\{\h*\r?\n([ \t]*)($ret)\h*\r?\n\3\})}{$2."\n".$4.$5}gme;

        # Opening brace on the same line, return on next line.
        s{(^([ \t]*$control[^\r\n]*?)\h*\{\h*\r?\n([ \t]*)($ret)\h*\r?\n([ \t]*)\})}{$2."\n".$3.$4}gme;

        # Single-line block.
        s{(^([ \t]*$control[^\r\n]*?)\h*\{\h*($ret)\h*\})}{$2." ".$3}gme;
    ' "$file_path"

    git add -- "$file_path"
done