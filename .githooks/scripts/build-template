#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=.githooks/scripts/lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

REPO_ROOT="${1:-$(git rev-parse --show-toplevel)}"
proj="$REPO_ROOT/Template/Template.csproj"

echo "[pre-commit] Building Template..."

dotnet_cmd build "$proj" --no-restore